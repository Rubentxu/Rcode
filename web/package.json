{
  "name": "rcode-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "e2e:web": "playwright test",
    "e2e:web:headed": "playwright test --headed",
    "e2e:web:debug": "playwright test --debug",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:generate": "cargo run -p rcode-gen-types -- ../web/src/api",
    "types:check": "cargo run -p rcode-gen-types -- ../web/src/api && git diff --exit-code src/api/generated-types.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/material-symbols-outlined": "^5.2.40",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "solid-js": "^1.9.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.15",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@vitest/ui": "^4.1.3",
    "autoprefixer": "^10.4.19",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.19",
    "type-fest": "^5.5.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.0.0",
    "vitest": "^4.1.3"
  }
}
